#!/bin/bash -xe

# REQUEST_DELAY=0.5, works but SSSLLLLOOOOWWWW
# 0.0 is no good, 429 rate-limiting
REQUEST_DELAY=0.2
MAX_CONCURRENT=1

pkill -f "bfs-ql serve" || true

sleep 1

