uv run bfs-ql serve --backend sparql --transport sse --port 8001 \
    --bif-contains --max-concurrent ${MAX_CONCURRENT} --request-delay ${REQUEST_DELAY} \
    --restrict-to-prefixes --log-level DEBUG --endpoint https://dbpedia.org/sparql \
    --prefix DBpedia=http://dbpedia.org/resource/ \
    --prefix DBpedia-owl=http://dbpedia.org/ontology/ \
    --description "DBpedia: open encyclopedia knowledge graph derived from Wikipedia"
